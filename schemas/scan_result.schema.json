{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unif-appsec.dev/schemas/scan_result.schema.json",
  "title": "Unified AppSec Scan Result Envelope",
  "type": "object",
  "additionalProperties": true,
  "required": ["scan_result_schema_version", "findings", "module_results"],
  "properties": {
    "scan_result_schema_version": { "type": "string" },
    "findings": {
      "type": "array",
      "items": { "$ref": "finding.schema.json" }
    },
    "module_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["module", "warnings", "errors", "metrics"],
        "properties": {
          "module": { "type": "string" },
          "warnings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["code", "message"],
              "properties": {
                "code": { "type": "string" },
                "message": { "type": "string" },
                "details": { "type": "object" }
              }
            }
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["code", "message"],
              "properties": {
                "code": { "type": "string" },
                "message": { "type": "string" },
                "details": { "type": "object" }
              }
            }
          },
          "metrics": { "type": "object" }
        }
      }
    },
    "scan_errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "details": { "type": "object" }
        }
      }
    }
  }
}
